{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.2,
    "max_tokens": 8192,
    "throttle_sec": 0.3,
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "huggingface",
        "repo": "transformers",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "OpenAI News",
        "url": "https://openai.com/news/rss.xml",
        "enabled": true,
        "category": "ai-company"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "open-source-ai"
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "ai-company"
      },
      {
        "name": "The Verge AI",
        "url": "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "llm-engineering"
      },
      {
        "name": "GitHub Trending Python",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/python.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "GitHub Trending Jupyter Notebook",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/jupyter-notebook.xml",
        "enabled": true,
        "category": "github-trending"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "OpenAI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        },
        {
          "subreddit": "ClaudeAI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 7.5,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "headers": ""
  }
}
